# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Environment & Secrets (NEVER commit these) ───────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env
*token.json*
*credentials.json*

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml

# ── Virtual Environments ──────────────────────────────────────
venv/
.venv/
env/
ENV/
backend/venv/
backend/.venv/

# ── Node / React ──────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/build/
frontend/dist/
/build
/out
dist/
/.next/
next-env.d.ts
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Frontend build cache (wildcard — no more explicit .pack lines) ──
frontend/node_modules/.cache/

# ── IDEs & Editors ────────────────────────────────────────────
.idea/
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── OS Files ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Uploads & Temporary Files ─────────────────────────────────
backend/uploads/
backend/tmp/
*.log
dump.rdb

# ── Archives & Large Binaries ─────────────────────────────────
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib
*.pem

# ── Misc ──────────────────────────────────────────────────────
*.bak
*.orig
.cache/
.vercel
.chainlit
chainlit.md
.ipynb_checkpoints/
.emergent/
.ac
