# ─────────────────────────────────────────────────────────────
# Frontend Environment Variables — copy this file to .env
# cp .env.example .env   (then fill in your actual values)
# ─────────────────────────────────────────────────────────────

# URL of the running FastAPI backend server
REACT_APP_BACKEND_URL=http://localhost:8000

# Supabase project credentials (from Project Settings > API)
# Use the ANON / public key here — never the service role key!
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here
